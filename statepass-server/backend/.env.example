# StatePass Sync Server — Environment Variables
# Copy this file to .env and fill in your values

# ─── PostgreSQL ───────────────────────────────────────────
DB_HOST=postgres
DB_PORT=5432
DB_NAME=statepass_sync
DB_USER=statepass
DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD_HERE
DB_SSL=false

# ─── JWT ──────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=CHANGE_ME_MINIMUM_32_CHARS_RANDOM_STRING_HERE

# ─── Server ───────────────────────────────────────────────
PORT=3000
NODE_ENV=production

# ─── CORS ─────────────────────────────────────────────────
# Comma-separated list of allowed origins (leave empty to allow none besides extensions)
ALLOWED_ORIGINS=http://localhost:3000
